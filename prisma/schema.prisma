// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  
}

// Enums
enum TaskInstanceStatus {
  TODO
  IN_PROGRESS
  DONE
  SKIPPED
}

enum OrgPermission {
  ORG_MANAGE
  ROLE_MANAGE
  TASK_CREATE
  TASK_UPDATE
  TASK_DELETE
  TASK_ASSIGN
  TASKINSTANCE_COMPLETE
}

// Core
model Organization {
  id           String   @id @default(cuid())
  title        String 
  ownerUserId  String  
  openTimeMin  Int?     // minutes from midnight (0-1439)
  closeTimeMin Int?

  memberships  Membership[]
  roles        Role[]
  tasks        Task[]
  cycles       TaskCycle[]
  taskInstances TaskInstance[]
  user       User   @relation(fields: [ownerUserId], references: [id])


  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([ownerUserId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String

  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id          String  @id @default(cuid())
  name        String?
  email       String  @unique
  image       String?  // <-- add this (Google provides a profile image URL)

  memberships Membership[]

  // NextAuth relations:
  accounts Account[]
  sessions Session[]
  organizations Organization[] 

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Membership {
  id        String   @id @default(cuid())
  orgId     String
  userId    String
  roleId    String

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role         @relation(fields: [roleId], references: [id], onDelete: Restrict)

  // For later "fairness":
  // capacityMinPerDay Int?

  taskAssignments TaskInstanceAssignee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, userId])
  @@index([orgId])
  @@index([userId])
}

model Role {
  id      String @id @default(cuid())
  orgId   String
  title   String
  key     String

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // Permissions (RBAC)
  permissions RolePermission[]

  // Qualification matrix (can do which tasks)
  eligibleFor TaskEligibility[]

  memberships Membership[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, key])
  @@index([orgId])
}

model RolePermission {
  id         String       @id @default(cuid())
  roleId     String
  permission OrgPermission

  role       Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([roleId, permission])
  @@index([roleId])
}

model Task {
  id            String  @id @default(cuid())
  orgId         String
  title         String
  description   String?
  durationMin   Int

  // preferred start time of day
  preferredStartTimeMin Int? // 0..1439

  // number of people required per occurrence
  peopleRequired Int @default(1)

  // recurrence constraints
  minWaitDays Int?
  maxWaitDays Int? // "must be done within X days"

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // if you want "qualified members", connect task to roles (or directly to memberships later)
  eligibility  TaskEligibility[]

  instances    TaskInstance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, title])
  @@index([orgId])
}

model TaskEligibility {
  id     String @id @default(cuid())
  taskId String
  roleId String

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt


  @@unique([taskId, roleId])
  @@index([taskId])
  @@index([roleId])
}

model TaskCycle {
  id      String  @id @default(cuid())
  orgId   String
  // planning horizon in days (weekly/monthly/custom). allow null if "system chooses"
  cycleDays Int?

  // later: versioning fields like effectiveFrom/effectiveTo
  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  instances TaskInstance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
}

model TaskInstance {
  id        String   @id @default(cuid())
  orgId     String
  taskId    String
  cycleId   String?

  status    TaskInstanceStatus @default(TODO)

  // scheduling for this instance
  scheduledStartAt DateTime?
  scheduledEndAt   DateTime?

  startedAt   DateTime?
  completedAt DateTime?

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  task      Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  cycle     TaskCycle?   @relation(fields: [cycleId], references: [id], onDelete: SetNull)

  assignees TaskInstanceAssignee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([taskId])
  @@index([cycleId])
  @@index([status])
}

model TaskInstanceAssignee {
  id             String @id @default(cuid())
  taskInstanceId String
  membershipId   String

  taskInstance   TaskInstance @relation(fields: [taskInstanceId], references: [id], onDelete: Cascade)
  membership     Membership   @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt


  @@unique([taskInstanceId, membershipId])
  @@index([membershipId])
}