generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// ─────────────────────────────────────
// ENUMS
// ─────────────────────────────────────

enum MembershipStatus {
  ACTIVE
  RESTRICTED
}

enum PermissionAction {
  MANAGE_MEMBERS
  MANAGE_ROLES
  MANAGE_TIMETABLE
  MANAGE_TASKS
  MANAGE_SETTINGS
  VIEW_TIMETABLE
}

enum EntryStatus {
  TODO
  IN_PROGRESS
  DONE
  SKIPPED
  CANCELLED
}

enum ViewType {
  DAILY
  WEEKLY
}

// ─────────────────────────────────────
// AUTH (NextAuth)
// ─────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String

  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────
// 1. USER
// ─────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?

  memberships               Membership[]
  ownedOrgs                 Organization[] @relation("OrgOwner")
  receivedFranchiseInvites  FranchiseToken[] @relation("ReceivedFranchiseInvites")

  accounts      Account[]
  sessions      Session[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─────────────────────────────────────
// 2. ORGANIZATION
// ─────────────────────────────────────

model Organization {
  id            String   @id @default(cuid())
  name          String
  image         String?

  ownerId       String
  owner         User     @relation("OrgOwner", fields: [ownerId], references: [id])

  // Franchise hierarchy
  parentId      String?
  parent        Organization?  @relation("OrgHierarchy", fields: [parentId], references: [id])
  children      Organization[] @relation("OrgHierarchy")

  // Location
  address       String?

  // Operating schedule
  operatingDays String[] // ["mon", "tue", "wed", "thu", "fri", "sat", "sun"]
  openTimeMin   Int?
  closeTimeMin  Int?
  timezone      String   @default("Australia/Sydney")

  memberships         Membership[]
  roles               Role[]
  tasks               Task[]
  timetableEntries    TimetableEntry[]
  timetableSettings   TimetableSettings?
  templates           Template[]
  franchiseTokens     FranchiseToken[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([ownerId])
  @@index([parentId])
}

// ─────────────────────────────────────
// 3. MEMBERSHIP
// ─────────────────────────────────────

model Membership {
  id            String   @id @default(cuid())

  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  orgId         String
  organization  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  workingDays   String[] // ["mon", "tue", "wed"]
  status        MembershipStatus @default(ACTIVE)

  memberRoles         MemberRole[]
  taskAssignments     TimetableEntryAssignee[]
  templateAssignments TemplateEntryAssignee[]

  joinedAt      DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, orgId])
  @@index([orgId])
  @@index([userId])
}

// ─────────────────────────────────────
// 4. ROLE
// ─────────────────────────────────────

model Role {
  id          String   @id @default(cuid())
  name        String
  color       String
  key         String   // "owner", "default", "cook"

  orgId       String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  isDeletable Boolean  @default(true)
  isDefault   Boolean  @default(false)

  permissions Permission[]
  memberRoles MemberRole[]
  eligibleFor TaskEligibility[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([orgId, key])
  @@index([orgId])
}

// ─────────────────────────────────────
// 5. PERMISSION
// ─────────────────────────────────────

model Permission {
  id          String   @id @default(cuid())
  action      PermissionAction

  roleId      String
  role        Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([action, roleId])
  @@index([roleId])
}

// ─────────────────────────────────────
// 6. MEMBER ROLE
// ─────────────────────────────────────

model MemberRole {
  id            String   @id @default(cuid())

  membershipId  String
  membership    Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  roleId        String
  role          Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  assignedAt    DateTime @default(now())

  @@unique([membershipId, roleId])
  @@index([membershipId])
  @@index([roleId])
}

// ─────────────────────────────────────
// 7. TASK
// ─────────────────────────────────────

model Task {
  id                    String   @id @default(cuid())
  name                  String
  description           String?
  color                 String

  orgId                 String
  organization          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  durationMin           Int      @default(60)
  minPeople             Int      @default(1)
  maxPeople             Int?
  priority              Int      @default(0)
  preferredStartTimeMin Int?     // 0-1439

  // Recurrence constraints for optimizer
  minWaitDays           Int?
  maxWaitDays           Int?

  eligibility           TaskEligibility[]
  timetableEntries      TimetableEntry[]
  templateEntries       TemplateEntry[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([orgId, name])
  @@index([orgId])
}

// ─────────────────────────────────────
// 8. TASK ELIGIBILITY
// ─────────────────────────────────────

model TaskEligibility {
  id     String @id @default(cuid())
  taskId String
  roleId String

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([taskId, roleId])
  @@index([taskId])
  @@index([roleId])
}

// ─────────────────────────────────────
// 9. TIMETABLE ENTRY
// ─────────────────────────────────────

model TimetableEntry {
  id            String   @id @default(cuid())

  orgId         String
  organization  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  taskId        String
  task          Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  // Snapshot from Task (frozen at creation time)
  taskName        String
  taskColor       String?
  taskDescription String?

  // Overridable per entry (defaults from Task, editable per day)
  priority      Int      @default(0)
  durationMin   Int

  date          DateTime
  startTimeMin  Int      // 0-1439
  endTimeMin    Int      // 0-1439

  status        EntryStatus @default(TODO)

  assignees     TimetableEntryAssignee[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([orgId])
  @@index([taskId])
  @@index([orgId, date])
}

// ─────────────────────────────────────
// 10. TIMETABLE ENTRY ASSIGNEE
// ─────────────────────────────────────

model TimetableEntryAssignee {
  id                String @id @default(cuid())
  timetableEntryId  String
  membershipId      String

  timetableEntry    TimetableEntry @relation(fields: [timetableEntryId], references: [id], onDelete: Cascade)
  membership        Membership     @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  createdAt         DateTime @default(now())

  @@unique([timetableEntryId, membershipId])
  @@index([membershipId])
}

// ─────────────────────────────────────
// 11. TIMETABLE SETTINGS
// ─────────────────────────────────────

model TimetableSettings {
  id              String   @id @default(cuid())

  orgId           String   @unique
  organization    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  viewType        ViewType @default(WEEKLY)
  startDay        String   @default("mon")
  slotDuration    Int      @default(30)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─────────────────────────────────────
// 12. TEMPLATE
// ─────────────────────────────────────

model Template {
  id              String   @id @default(cuid())
  name            String

  orgId           String
  organization    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  cycleLengthDays Int      @default(7)

  entries         TemplateEntry[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([name, orgId])
  @@index([orgId])
}

model TemplateEntry {
  id            String   @id @default(cuid())

  templateId    String
  template      Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  taskId        String
  task          Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  // Overridable per entry
  priority      Int      @default(0)
  durationMin   Int?     // null = use Task default

  dayIndex      Int      // 0 to cycleLengthDays - 1
  startTimeMin  Int      // 0-1439
  endTimeMin    Int      // 0-1439

  assignees     TemplateEntryAssignee[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TemplateEntryAssignee {
  id                String @id @default(cuid())
  templateEntryId   String
  membershipId      String

  templateEntry     TemplateEntry @relation(fields: [templateEntryId], references: [id], onDelete: Cascade)
  membership        Membership    @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  createdAt         DateTime @default(now())

  @@unique([templateEntryId, membershipId])
  @@index([membershipId])
}

// ─────────────────────────────────────
// 13. FRANCHISE TOKEN
// ─────────────────────────────────────

model FranchiseToken {
  id           String   @id @default(cuid())
  token        String   @unique @default(cuid())

  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  invitedEmail String
  usedByOrgId  String?  @unique

  // In-app invite: links to an existing user account
  recipientId  String?
  recipient    User?    @relation("ReceivedFranchiseInvites", fields: [recipientId], references: [id], onDelete: SetNull)

  expiresAt    DateTime
  usedAt       DateTime?
  declinedAt   DateTime?

  createdAt    DateTime @default(now())

  @@index([recipientId])
}